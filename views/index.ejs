<!DOCTYPE html>
<html lang="sv">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>CV</title>
  <link rel="stylesheet" href="styles.css">
</head>

<body>
  <header>
    <nav>
      <a href="/index">Startsida</a> - <a href="/add">Lägg till kurs</a> - <a href="about">Om</a>
    </nav>
  </header>

  <main>
    <h1>Befintliga kurser</h1>

    <div class="courses-container">
      <table class="courses-table">
        <thead>
          <tr>
            <th>Kurskod</th>
            <th>Kursnamn</th>
            <th>Kursplan</th>
            <th>Progression</th>
          </tr>
        </thead>
        <%# Rendera listan över kurser och loopa ut %>
        <tbody class="courses-list">
          <% courses.forEach(course=> {
            %>
            <tr>
              <td>
                <%= course.coursecode %>
              </td>
              <td>
                <%= course.coursename %>
              </td>
              <td>
                <a href="<%= course.syllabus %>" target="_blank">Länk</a>
              </td>
              <td>
                <%= course.progression %>
              </td>
              <td>
                <form action="/delete/<%= course.id %>" method="post">
                  <button type="submit">Radera</button>
              </td>
              <td>
                <%= new Date(course.created_at).toLocaleDateString('sv-SE') %>
                  <%= new Date(course.created_at).toLocaleTimeString('sv-SE', { hour: '2-digit' , minute: '2-digit' })
                    %>
              </td>
              </form>
            </tr>

            <% }); %>
        </tbody>
      </table>
    </div>
  </main>

  <footer>
    <p> Lab 1 serverbaserad webbutveckling av Rune Granath</p>
  </footer>


</body>

</html>